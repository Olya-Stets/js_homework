(+null == false) < 1; // false - +null переводиться в число 0, 0 дорівнює false, тобто отримуємо true, true переводиться в число 1, 1 не більше за 1

false && true || true // true - false && true повертає останє вірне або перше невірне значення, false || true повертає вірне значення 

false && (false || true); // false - (false || true) повертає вірне значення, false && true повертає останє вірне або перше невірне значення

