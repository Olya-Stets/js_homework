'10' - 5 === 6; // false - '10' переводиться в чисто 10, 10-5=5, 5 не дорівнює 6 

true + false // 1 - true переводиться в число 1, false переводиться в число 0, 1+0=1

'4px' - 3 // NaN - '4px' переводиться в число і виходить NaN, NaN-3=NaN

'4' - 3 // 1 - '4' переводиться в число, 4-3=1

'6' + 3 ** 0; // 61 - 3 в 0 ступені = 1, 6 це строка і відбувається конкатинація

12 / '6' // 2 - '6' переводиться в число, 12/6=2

'10' + (5 === 6); // '10false' - (5 === 6) повертає false, false переводиться в строку і відбувається конкатинація

null == '' // false - null = undefined, порожній рядок не undefined

3 ** (9 / 3); // 27 - (9 / 3) = 3, 3 в ступені 3 = 27

!!'false' == !!'true' // false - не не false не дорівнює не не true

